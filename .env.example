# Copy this file to ".env" then fill in your credentials.
# NEVER share the .env file (it contains your password).

# --- Email (Gmail example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.address@gmail.com
# Gmail APP PASSWORD (16 characters), NOT your normal password.
# Create one here: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# Sender and recipient (default = SMTP_USER)
EMAIL_FROM=your.address@gmail.com
EMAIL_TO=your.address@gmail.com

# --- Check frequency (in minutes) ---
CHECK_INTERVAL_MINUTES=15

# --- Browser ---
# false = VISIBLE Chrome window (recommended, bypasses DataDome).
# true  = hidden browser (often blocked by Fnac, avoid).
HEADLESS=false
# Wait time after each page load (ms).
PAGE_WAIT_MS=5000
